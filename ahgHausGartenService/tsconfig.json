{
  "include": [
    "api/**/*.ts",
    "server/**/*.ts",
    "vite.config.ts",
    "src/vue-shim.d.ts"
  ],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "noEmit": true
  }
}
