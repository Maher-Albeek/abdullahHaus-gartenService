# Railway service variable:
# DATABASE_URL=${{ MySQL.MYSQL_URL }}
DATABASE_URL=mysql://user:password@host:3306/database

# Used only to create the administrator account when it does not exist:
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-password
SESSION_SECRET=replace-with-a-separate-long-random-secret

# Password-reset email delivery through Brevo transactional email:
APP_URL=https://example.com
BREVO_API_KEY=xkeysib-your-api-key
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=AHG Haus & Gartenservice
